{
  "@context": {
    "@version": 1.1,
    "gosum":  "https://schema.gosum.eu/persona/v0.1#",
    "schema": "https://schema.org/",
    "sec":    "https://w3id.org/security#",
    "xsd":    "http://www.w3.org/2001/XMLSchema#",

    "id":   "@id",
    "type": "@type",
    "Persona": "gosum:Persona",

    "identity":    "gosum:identity",
    "brand":       "gosum:brand",
    "personality": "gosum:personality",
    "voice":       "gosum:voice",
    "knowledge":   "gosum:knowledge",
    "guardrails":  "gosum:guardrails",
    "behavior":    "gosum:behavior",
    "telemetry":   "gosum:telemetry",
    "bindings":    "gosum:bindings",
    "provenance":  "gosum:provenance",

    "did":             "gosum:did",
    "name":            "schema:name",
    "displayName":     "gosum:displayName",
    "version":         "gosum:version",
    "contentHash":     "gosum:contentHash",
    "previousVersion": { "@id": "gosum:previousVersion", "@type": "@id" },
    "license":         "gosum:license",

    "ownerOrg":           { "@id": "gosum:ownerOrg", "@type": "@id" },
    "brandName":          "schema:name",
    "brandVoiceDocument": { "@id": "gosum:brandVoiceDocument", "@type": "@id" },
    "legalContact":       "gosum:legalContact",
    "escalationContact":  "gosum:escalationContact",
    "complianceProfiles": { "@id": "gosum:complianceProfiles", "@container": "@list" },
    "verticalContext":    "gosum:verticalContext",
    "signoffStatus":      "gosum:signoffStatus",
    "signoffDate":        { "@id": "gosum:signoffDate", "@type": "xsd:dateTime" },

    "archetype":          "gosum:archetype",
    "archetypeCustom":    "gosum:archetypeCustom",
    "oceanTraits":        "gosum:oceanTraits",
    "openness":           { "@id": "gosum:openness",          "@type": "xsd:decimal" },
    "conscientiousness":  { "@id": "gosum:conscientiousness", "@type": "xsd:decimal" },
    "extraversion":       { "@id": "gosum:extraversion",      "@type": "xsd:decimal" },
    "agreeableness":      { "@id": "gosum:agreeableness",     "@type": "xsd:decimal" },
    "neuroticism":        { "@id": "gosum:neuroticism",       "@type": "xsd:decimal" },
    "additionalTraits":   "gosum:additionalTraits",
    "styleVector":        "gosum:styleVector",
    "formality":          { "@id": "gosum:formality",   "@type": "xsd:decimal" },
    "humor":              { "@id": "gosum:humor",       "@type": "xsd:decimal" },
    "verbosity":          { "@id": "gosum:verbosity",   "@type": "xsd:decimal" },
    "pace":               { "@id": "gosum:pace",        "@type": "xsd:decimal" },
    "warmth":             { "@id": "gosum:warmth",      "@type": "xsd:decimal" },
    "directness":         { "@id": "gosum:directness",  "@type": "xsd:decimal" },
    "playfulness":        { "@id": "gosum:playfulness", "@type": "xsd:decimal" },
    "allowedTones":       { "@id": "gosum:allowedTones",     "@container": "@list" },
    "forbiddenTones":     { "@id": "gosum:forbiddenTones",   "@container": "@list" },
    "catchphrases":       { "@id": "gosum:catchphrases",     "@container": "@list" },
    "forbiddenPhrases":   { "@id": "gosum:forbiddenPhrases", "@container": "@list" },
    "narrativeBackstory": "gosum:narrativeBackstory",
    "narrativeSpine":     "gosum:narrativeSpine",
    "origin":             "gosum:origin",
    "definingEvents":     { "@id": "gosum:definingEvents", "@container": "@list" },
    "themes":             { "@id": "gosum:themes",         "@container": "@list" },
    "nameAddressForm":    "gosum:nameAddressForm",

    "defaultLanguage":    "gosum:defaultLanguage",
    "supportedLanguages": { "@id": "gosum:supportedLanguages", "@container": "@list" },
    "voiceProfile":       "gosum:voiceProfile",
    "gender":             "gosum:gender",
    "ageRange":           "gosum:ageRange",
    "accent":             "gosum:accent",
    "register":           "gosum:register",
    "prosody":            "gosum:prosody",
    "rate":               { "@id": "gosum:rate",   "@type": "xsd:decimal" },
    "pitch":              { "@id": "gosum:pitch",  "@type": "xsd:decimal" },
    "energy":             { "@id": "gosum:energy", "@type": "xsd:decimal" },
    "providerBindings":   { "@id": "gosum:providerBindings", "@container": "@list" },
    "provider":           "gosum:provider",
    "voiceId":            "gosum:voiceId",
    "languages":          { "@id": "gosum:languages",    "@container": "@list" },
    "fallbackOrder":      { "@id": "gosum:fallbackOrder", "@container": "@list" },
    "latencyBudgetMs":    { "@id": "gosum:latencyBudgetMs", "@type": "xsd:integer" },

    "domainScope":        "gosum:domainScope",
    "retrievalSources":   { "@id": "gosum:retrievalSources", "@container": "@list" },
    "endpoint":           { "@id": "gosum:endpoint", "@type": "@id" },
    "authRef":            "gosum:authRef",
    "priority":           { "@id": "gosum:priority", "@type": "xsd:integer" },
    "knowledgeCutoff":    { "@id": "gosum:knowledgeCutoff", "@type": "xsd:date" },
    "freshnessPolicy":    "gosum:freshnessPolicy",
    "factCheckingTier":   "gosum:factCheckingTier",

    "topics":             "gosum:topics",
    "allowed":            { "@id": "gosum:allowed",    "@container": "@list" },
    "restricted":         { "@id": "gosum:restricted", "@container": "@list" },
    "banned":             { "@id": "gosum:banned",     "@container": "@list" },
    "restrictedActions":  { "@id": "gosum:restrictedActions", "@container": "@list" },
    "complianceFlags":       "gosum:complianceFlags",
    "aiDisclosure":          "gosum:aiDisclosure",
    "aiDisclosureText":      "gosum:aiDisclosureText",
    "profanityFilter":       "gosum:profanityFilter",
    "ageGate":               { "@id": "gosum:ageGate", "@type": "xsd:integer" },
    "gdprDataSubjectRights": "gosum:gdprDataSubjectRights",
    "escalationRules":    { "@id": "gosum:escalationRules", "@container": "@list" },
    "trigger":            "gosum:trigger",
    "action":             "gosum:action",
    "contactRef":         "gosum:contactRef",
    "refusalTemplate":    "gosum:refusalTemplate",
    "safetyTier":         "gosum:safetyTier",

    "greeting":            "gosum:greeting",
    "greetingPolicy":      "gosum:greetingPolicy",
    "closing":             "gosum:closing",
    "errorFallback":       "gosum:errorFallback",
    "outOfScopeFallback":  "gosum:outOfScopeFallback",
    "silenceFallback":     "gosum:silenceFallback",
    "silenceTimeoutSec":   { "@id": "gosum:silenceTimeoutSec", "@type": "xsd:integer" },
    "interruptionPolicy":  "gosum:interruptionPolicy",
    "smallTalk":           "gosum:smallTalk",
    "humorLevel":          "gosum:humorLevel",
    "repetitionAvoidance": "gosum:repetitionAvoidance",

    "auditPolicy":             "gosum:auditPolicy",
    "transcriptRetentionDays": { "@id": "gosum:transcriptRetentionDays", "@type": "xsd:integer" },
    "piiHandling":             "gosum:piiHandling",
    "consentDisclosure":       "gosum:consentDisclosure",
    "analyticsOptIn":          "gosum:analyticsOptIn",
    "dataResidency":           { "@id": "gosum:dataResidency", "@container": "@list" },
    "redactionRules":          { "@id": "gosum:redactionRules", "@container": "@list" },

    "hardwareAdapters":    { "@id": "gosum:hardwareAdapters", "@container": "@list" },
    "vendor":              "gosum:vendor",
    "model":               "gosum:model",
    "firmwareMin":         "gosum:firmwareMin",
    "capabilities":        { "@id": "gosum:capabilities", "@container": "@list" },
    "runtimeConfig":       "gosum:runtimeConfig",
    "llmAdapter":          "gosum:llmAdapter",
    "llmModelHint":        "gosum:llmModelHint",
    "contextWindowTokens": { "@id": "gosum:contextWindowTokens", "@type": "xsd:integer" },
    "temperatureCeiling":  { "@id": "gosum:temperatureCeiling",  "@type": "xsd:decimal" },
    "featureFlags":        "gosum:featureFlags",

    "createdAt":   { "@id": "gosum:createdAt", "@type": "xsd:dateTime" },
    "updatedAt":   { "@id": "gosum:updatedAt", "@type": "xsd:dateTime" },
    "signedBy":    { "@id": "gosum:signedBy",  "@type": "@id" },
    "signature":   { "@id": "sec:proof" },
    "revisionLog": { "@id": "gosum:revisionLog", "@container": "@list" },
    "changeNote":  "gosum:changeNote",
    "breaking":    "gosum:breaking",
    "notes":       "gosum:notes",
    "lineage":     "gosum:lineage"
  }
}
